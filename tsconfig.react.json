{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "./resources/.compiled/react",
    "rootDir": "./resources/react"
  },
  "include": [
    "resources/react/**/*.ts",
    "resources/react/**/*.tsx"
  ],
  "exclude": [
    "resources/.compiled"
  ]
}
